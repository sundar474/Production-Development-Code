{
  "family": "observability-tempo",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["EC2"],
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/observability-ecs-task-role",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/observability-ecs-execution-role",
  "cpu": "2048",
  "memory": "4096",
  "containerDefinitions": [
    {
      "name": "tempo",
      "image": "<ACCOUNT_ID>.dkr.ecr.us-east-1.amazonaws.com/observability/tempo:latest",
      "essential": true,
      "portMappings": [
        {"containerPort": 3200, "protocol": "tcp"},
        {"containerPort": 4317, "protocol": "tcp"},
        {"containerPort": 4318, "protocol": "tcp"}
      ],
      "environment": [
        {"name": "AWS_REGION",                   "value": "us-east-1"},
        {"name": "S3_BUCKET",                    "value": "observability-uat-<ACCOUNT_ID>"},
        {"name": "PROMETHEUS_REMOTE_WRITE_URL",  "value": "http://prometheus.observability.local:9090/api/v1/write"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/observability/tempo",
          "awslogs-region":        "us-east-1",
          "awslogs-stream-prefix": "tempo",
          "awslogs-create-group":  "true"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget --no-verbose --tries=1 --spider http://localhost:3200/ready || exit 1"],
        "interval": 15,
        "timeout": 5,
        "retries": 5,
        "startPeriod": 60
      }
    }
  ]
}
