{
  "family": "observability-loki",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["EC2"],
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/observability-ecs-task-role",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/observability-ecs-execution-role",
  "cpu": "2048",
  "memory": "6144",
  "containerDefinitions": [
    {
      "name": "loki",
      "image": "<ACCOUNT_ID>.dkr.ecr.us-east-1.amazonaws.com/observability/loki:latest",
      "essential": true,
      "portMappings": [
        {"containerPort": 3100, "protocol": "tcp"},
        {"containerPort": 9095, "protocol": "tcp"}
      ],
      "environment": [
        {"name": "AWS_REGION", "value": "us-east-1"},
        {"name": "S3_BUCKET",  "value": "observability-uat-<ACCOUNT_ID>"}
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group":         "/ecs/observability/loki",
          "awslogs-region":        "us-east-1",
          "awslogs-stream-prefix": "loki",
          "awslogs-create-group":  "true"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "wget --no-verbose --tries=1 --spider http://localhost:3100/ready || exit 1"],
        "interval": 10,
        "timeout": 5,
        "retries": 5,
        "startPeriod": 60
      }
    }
  ]
}
