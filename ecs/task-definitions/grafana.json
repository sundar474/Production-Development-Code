{
  "family": "observability-grafana",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "EC2"
  ],
  "taskRoleArn": "arn:aws:iam::036475471569:role/observability-ecs-task-role",
  "executionRoleArn": "arn:aws:iam::036475471569:role/observability-ecs-execution-role",
  "cpu": "512",
  "memory": "512",
  "volumes": [
    {
      "name": "grafana-efs",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-0472d91d201b45e43",
        "rootDirectory": "/grafana",
        "transitEncryption": "ENABLED",
        "authorizationConfig": {
          "iam": "ENABLED"
        }
      }
    }
  ],
  "containerDefinitions": [
    {
      "name": "grafana",
      "image": "036475471569.dkr.ecr.us-east-1.amazonaws.com/observability/grafana:latest",
      "essential": true,
      "cpu": 512,
      "memory": 512,
      "portMappings": [
        {
          "containerPort": 3000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "GF_SECURITY_ADMIN_USER",
          "value": "admin"
        },
        {
          "name": "GF_SECURITY_ADMIN_PASSWORD",
          "value": "changeme"
        },
        {
          "name": "GF_AUTH_ANONYMOUS_ENABLED",
          "value": "false"
        },
        {
          "name": "GF_SERVER_ROOT_URL",
          "value": "http://grafana.observability.local:3000"
        },
        {
          "name": "GF_FEATURE_TOGGLES_ENABLE",
          "value": "traceqlEditor"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "grafana-efs",
          "containerPath": "/var/lib/grafana",
          "readOnly": false
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/observability/grafana",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "grafana",
          "awslogs-create-group": "true"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "wget --no-verbose --tries=1 --spider http://localhost:3000/api/health || exit 1"
        ],
        "interval": 15,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}